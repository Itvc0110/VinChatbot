# App
APP_ENV=development
DEFAULT_ANSWER_LANGUAGE=vi

# OpenRouter - required for /chat, embeddings, rerank and Qdrant indexing
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
OPENROUTER_APP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=VinChatbot

# Vector database
# Leave QDRANT_URL empty to use local embedded Qdrant at QDRANT_LOCAL_PATH.
# Set QDRANT_URL and QDRANT_API_KEY for Qdrant Cloud.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=vinuni_documents
QDRANT_LOCAL_PATH=data/qdrant

# LangGraph short-term memory
# memory is fine for local dev. Use postgres for production.
CHECKPOINTER_BACKEND=memory
POSTGRES_URI=

# Data paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# Crawling - used by scripts/crawl_seed.py and POST /ingest/run
CRAWL_USER_AGENT=VinChatbotBot/0.1 (+https://vinuni.edu.vn)
CRAWL_TIMEOUT_SECONDS=30
CRAWL_RATE_LIMIT_SECONDS=1.0

# Crawl safety bounds
CRAWL_MAX_PAGES_TOTAL=500
CRAWL_MAX_VINUNI_PAGES_PER_DOMAIN=50
CRAWL_MAX_EXTERNAL_PAGES_PER_DOMAIN=10
CRAWL_VINUNI_MAX_DEPTH=2
CRAWL_EXTERNAL_MAX_DEPTH=1
