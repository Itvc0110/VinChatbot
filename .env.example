# =============================================================================
# VinChatbot environment example
# Copy this file to .env and fill secrets before running the app.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
DEFAULT_ANSWER_LANGUAGE=vi

# -----------------------------------------------------------------------------
# OpenRouter
# Required for /chat, embeddings, rerank, and Qdrant indexing.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
OPENROUTER_APP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=VinChatbot

# -----------------------------------------------------------------------------
# Guardrails (layered). Rule-based regex/deobfuscation runs first (free); the API
# guards run only on non-confident turns.
# Safety tier: openai_moderation (omni-moderation-latest, free) | llama_guard | off
# Injection+scope tier: a small multilingual instruct model via OpenRouter (GUARD_MODEL).
# -----------------------------------------------------------------------------
SAFETY_GUARD_BACKEND=openai_moderation
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODERATION_MODEL=omni-moderation-latest
LLAMA_GUARD_MODEL=meta-llama/llama-guard-4-12b
GUARD_MODEL=qwen/qwen-2.5-7b-instruct
ENABLE_LLM_GUARD=true
ENABLE_SAFETY_ON_ALL=false
ENABLE_OUTPUT_MODERATION=false

# -----------------------------------------------------------------------------
# Vector database
# Qdrant is the canonical backend. Leave QDRANT_URL empty to use local embedded
# Qdrant at QDRANT_LOCAL_PATH; set QDRANT_URL + QDRANT_API_KEY for Qdrant Cloud.
# Pinecone/Chroma are opt-in: change VECTOR_STORE_BACKEND and install their extras
# with `pip install -e ".[vector-backups]"` plus the relevant keys below.
# -----------------------------------------------------------------------------
VECTOR_STORE_BACKEND=qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=vinuni_documents
QDRANT_LOCAL_PATH=data/qdrant
QDRANT_TIMEOUT_SECONDS=120
QDRANT_BATCH_SIZE=16
CHROMA_COLLECTION=vinuni_documents
CHROMA_PERSIST_DIR=data/chroma
PINECONE_API_KEY=
PINECONE_INDEX_NAME=vinuni-documents
PINECONE_NAMESPACE=

# -----------------------------------------------------------------------------
# LangGraph short-term memory
# CHECKPOINTER_BACKEND=memory is fine for local dev.
# Use CHECKPOINTER_BACKEND=postgres with POSTGRES_URI for production.
# -----------------------------------------------------------------------------
CHECKPOINTER_BACKEND=memory
POSTGRES_URI=

# -----------------------------------------------------------------------------
# Data paths
# raw: normalized crawled documents
# processed: crawl manifest, structured records, chunks
# -----------------------------------------------------------------------------
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# -----------------------------------------------------------------------------
# Crawler
# Used by scripts/crawl_seed.py and POST /ingest/run.
# -----------------------------------------------------------------------------
CRAWL_USER_AGENT=VinChatbotBot/0.1 (+https://vinuni.edu.vn)
CRAWL_TIMEOUT_SECONDS=30
CRAWL_RATE_LIMIT_SECONDS=0.5

# -----------------------------------------------------------------------------
# Crawl safety bounds
# -----------------------------------------------------------------------------
CRAWL_MAX_PAGES_TOTAL=50000
CRAWL_MAX_VINUNI_PAGES_PER_DOMAIN=10000
CRAWL_MAX_EXTERNAL_PAGES_PER_DOMAIN=250
CRAWL_VINUNI_MAX_DEPTH=25
CRAWL_EXTERNAL_MAX_DEPTH=3

# -----------------------------------------------------------------------------
# Asset metadata
# ENABLE_IMAGE_ASSET_EXTRACTION=true stores image/file/table metadata.
# IMAGE_DOWNLOAD_ENABLED=false means HTML images are described from context only.
# Turn IMAGE_DOWNLOAD_ENABLED=true only when you want direct image fetching/OCR.
# -----------------------------------------------------------------------------
ENABLE_IMAGE_ASSET_EXTRACTION=true
IMAGE_DOWNLOAD_ENABLED=false
IMAGE_MAX_ASSET_MB=5
IMAGE_DESCRIPTION_MODE=context

# -----------------------------------------------------------------------------
# OCR
# Selected engine/model: PaddleOCR PP-OCRv5 English.
# Disabled by default because PaddleOCR is optional and heavy.
# PDF pages are OCR candidates when text length is below OCR_MIN_TEXT_CHARS_PER_PAGE.
# -----------------------------------------------------------------------------
ENABLE_OCR=false
OCR_ENGINE=paddleocr
OCR_LANG=en
OCR_MODEL=PP-OCRv5
OCR_MAX_IMAGE_MB=5
OCR_MAX_PDF_PAGES=20
OCR_MIN_TEXT_CHARS_PER_PAGE=40
OCR_STORE_TEXT=true
OCR_STORE_BOXES=false
