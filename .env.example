# =============================================================================
# VinChatbot environment example
# Copy this file to .env and fill secrets before running the app.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
DEFAULT_ANSWER_LANGUAGE=vi
# Time awareness (Phase 1.9): inject today's date + current academic year/term (Asia/Ho_Chi_Minh) into
# each turn, and expose a get_current_datetime tool, so "what semester am I in?" works. Fail-open.
ENABLE_TIME_AWARENESS=true
# Rate limiting (Phase 1.10): per-process sliding window on the API (per client IP). OFF by default.
# RATE_LIMIT_MAX_REQUESTS requests per RATE_LIMIT_WINDOW_SECONDS → 429 + Retry-After when exceeded.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
# Answer/routing temperature (Phase 1.11): 0.0 = deterministic answers (consistency fix). Raise toward
# 0.1-0.3 only if you want answer diversity at the cost of run-to-run stability. Guard models keep theirs.
LLM_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# Observability (Phase 1.5a) — structured logging + per-turn cost/token capture.
# LOG_FORMAT=auto -> JSON in prod, human-readable text in development.
# No API keys required for this tier. Langfuse tracing (1.5b) is added separately.
# Per-stage ledger (Phase C): when ENABLE_COST_TRACKING=true the chat_turn log carries true turn cost
# summed across ALL billed stages (supervisor route, query expansion, specialist answer, LLM/safety
# guards, rerank) plus a `stages` breakdown — not the answer-stage-only undercount. The eval report
# (scripts/run_eval.py) adds the same ledger (cost/latency/model_calls per stage, p95) + a
# `confidently_wrong_rate` (answers SERVED wrong without declining). Rerank cost is an estimate
# (~$2/1k searches); models priced via observability.MODEL_PRICES_USD_PER_M (unknown models => $0).
# -----------------------------------------------------------------------------
LOG_FORMAT=auto
LOG_LEVEL=INFO
LOG_REDACT_PII=true
ENABLE_COST_TRACKING=true

# Langfuse tracing (Phase 1.5b). Install with `pip install -e ".[observability]"`.
# Fail-open: disabled unless ENABLE_LANGFUSE=true AND both keys are set. Get free keys at
# https://cloud.langfuse.com (Settings -> API Keys), or self-host and set LANGFUSE_HOST.
# LOG_REDACT_PII=true also masks email/phone in traces before they are sent.
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# OpenRouter
# Required for /chat, embeddings, rerank, and Qdrant indexing.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
# Tavily web-search key (optional; used by the web-search tool path). Leave empty to disable.
TAVILY_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
# Embedding (Phase 1.14): multilingual-e5-large via OpenRouter (best VI<->EN, no extra key, 1024-d).
OPENROUTER_EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_BACKEND=openrouter
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
OPENROUTER_APP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=VinChatbot
# Rerank-after-fusion (Phase 1.6): rerank the RRF-fused pool ONCE per multi-query turn instead of
# once per query variant (~67% rerank-cost cut). Shipped ON (A/B accepted a ~1-case tradeoff).
ENABLE_RERANK_AFTER_FUSION=true
# Adaptive retrieval (Phase 1.7): point-lookups (calendar/financial/year/amount) read the full
# section + strict prompt; calendar drops paraphrase expansion (precision). Shipped ON.
ENABLE_ADAPTIVE_RETRIEVAL=true
# Structured lookup (CODEX P0, default OFF → A/B before promote): for exact calendar point-lookups
# (Stage 1; fees in Stage 2), consult a DETERMINISTIC record index BEFORE vector search and return the
# one exact row — never the adjacent near-identical row vector retrieval leaks (the grounded-but-wrong
# residuals). Reads the structured records already produced at ingest (no re-embedding). Fail-open: any
# miss/error → the existing vector path runs unchanged. Empty path → <PROCESSED_DATA_DIR>/structured_records.json.
ENABLE_STRUCTURED_LOOKUP=false
STRUCTURED_LOOKUP_RECORDS_PATH=
# List mode (Phase 1.27a): multi-row "list" questions ("tuition for ALL programs") widen retrieval +
# enumerate every row; structured _match_fee returns the full tuition matrix. is_list_lookup excludes VI
# rate words (mỗi/từng). Default off → byte-identical.
ENABLE_LIST_MODE=false
RETRIEVAL_LIST_MAX_K=20
# Cross-lingual policy retrieval (Phase 1.20, default off → A/B): VI policy questions undermatch the
# (often EN) canonical policy doc; for a VI question routed to the policy domain, force the EN translation
# variant so the canonical doc is RRF-fused in. Calendar/financial excluded (structured lookup / precision).
ENABLE_CROSSLINGUAL_POLICY=false
# Canonical policy-page boost (Phase 1.20, TOPIC-TARGETED redesign, default off → A/B): lift the
# all-policies detail page (policy_html / financial_policy) over VI governance "magnet" PDFs ONLY when
# the page TITLE's topic overlaps the query — restoring the on-topic canonical page the multilingual
# reranker's same-language bias demotes after RRF fusion. Cross-lingual: reuses Lever 1's EN translation
# (threaded as topic_terms) so a VI query matches the EN title. Title-gating (vs the dropped blanket
# ×1.15) means OFF-topic canonical pages are NOT boosted — avoiding the EN regressions that killed v1.
ENABLE_CANONICAL_POLICY_BOOST=false
# Policy doc-pin (Phase 1.21, default off -> A/B): the real magnet fix. A retrieval probe showed the
# canonical policy page IS retrieved but the magnet PDF / its own PDF twin / on-topic non-policy pages
# out-rank it after rerank, with score gaps too large for any boost (so the canonical-boost above was
# rejected). When a policy question confidently names ONE curated student-facing topic, fetch that
# canonical page by source_url and PIN it to the front of the context. Single-winner + fail-open: 0 or
# >1 topic matches => byte-identical vector path. Fires for all routings EXCEPT calendar. PROMOTED in the
# live .env: A/B (k=24, n=172) 0.913->0.953 (+10/-1 real), policy 0.676->0.912, guards 1.000. Default off here.
ENABLE_POLICY_DOC_PIN=false
# Policy auto-index (Phase 1.24, default off → A/B): adds an ingest-built title-overlap FALLBACK
# (data/processed/policy_topic_index.json, regenerated by scripts/build_policy_topic_index.py) AFTER the
# curated doc-pin map — covers all ~155 canonical pages + future uploads. Curated map keeps precedence
# (golden precision preserved). Off until an A/B confirms guards stay 1.000 (the broad index can match some
# adversarial/safety/unanswerable queries; guards run independently so should still refuse).
ENABLE_POLICY_AUTO_INDEX=false
# Mass cache (Phase A2c, default off): exact-match Redis cache of LLM responses + rerank scores, keyed on
# the FULL prompt/content -> reproducible A/Bs (kills run-to-run LLM/rerank noise) AND cost cuts. Fail-open:
# no REDIS_URL or any redis error => cache MISS (never an exception). Keys namespaced by CACHE_VERSION (bump
# to invalidate after a logic-only change). CACHE_TTL_SECONDS bounds growth (0 = no expiry). Use a PLAIN
# redis:// URL (exact-match) — NOT a semantic cache. Set eviction to allkeys-lru on the server.
REDIS_URL=
ENABLE_LLM_CACHE=false
ENABLE_RERANK_CACHE=false
CACHE_VERSION=v1
CACHE_TTL_SECONDS=2592000
# Router v2 (Phase 1.23c, default off → A/B): hardened SUPERVISOR_SYSTEM that routes by INTENT (WHEN→calendar
# vs is-there-a-rule→policy; fixes course-evaluation mis-routes) + a deterministic-first gate (strong
# unambiguous keyword signal routes without the LLM). Fail-safe: off = current router behaviour.
ENABLE_ROUTER_V2=false
# Cross-lingual expansion (Phase 1.8). ALWAYS-ON translation now OFF (Phase 1.14): e5 matches VI<->EN
# natively, so always-on is unnecessary noise + the main nondeterminism source. Cross-lingual is instead
# agent-decided + applied as the deterministic REACTIVE second loop (only when the native pass is weak).
ENABLE_CROSSLINGUAL_EXPANSION=false
# Reactive expansion (Phase 1.11): single deterministic query first (cross-lingual translation kept on
# for recall, paraphrase gated); fan out to paraphrases ONLY when the top result is weak
# (< REACTIVE_EXPANSION_MIN_SCORE). SHIPPED ON: A/B 0.885 -> 0.923, guards 1.000.
ENABLE_REACTIVE_EXPANSION=true
REACTIVE_EXPANSION_MIN_SCORE=0.35
# Date-format normalization (Phase 1.12): add the other canonical month+year forms of a date query
# ("tháng 6 năm 2026" <-> "June 2026" <-> "6/2026") so retrieval is phrasing-independent. Regex, no-op
# for non-date queries.
ENABLE_DATE_NORMALIZATION=true

# -----------------------------------------------------------------------------
# Guardrails (layered). Rule-based regex/deobfuscation runs first (free); the API
# guards run only on non-confident turns.
# Safety tier: openai_moderation (omni-moderation-latest, FREE; blocked 8/8 in head-to-head — needs a
#   VALID OpenAI key, a 401 fails OPEN but is now logged at WARNING) | llama_guard (Llama-Guard-4 via
#   OpenRouter — fallback when no OpenAI key; misses some multilingual harassment) | off
# Injection+scope tier: a small multilingual instruct model via OpenRouter (GUARD_MODEL) — complements
#   the safety tier on injection. Guards run only on non-confident turns.
# -----------------------------------------------------------------------------
SAFETY_GUARD_BACKEND=openai_moderation
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODERATION_MODEL=omni-moderation-latest
LLAMA_GUARD_MODEL=meta-llama/llama-guard-4-12b
GUARD_MODEL=qwen/qwen-2.5-7b-instruct
ENABLE_LLM_GUARD=true
ENABLE_SAFETY_ON_ALL=false
ENABLE_OUTPUT_MODERATION=false
# Output-audit critic (Phase 1.25/B): LLM groundedness judge on high-stakes point-lookups. REJECTED as a
# grounding judge (over-degraded correct date answers, +26%/+44% latency, no benefit) — kept gated OFF for a
# future SECURITY use (output secret/safety-leak detection). OUTPUT_AUDIT_MODEL empty => falls back to
# GUARD_MODEL; set e.g. openai/gpt-4o-mini to decouple it from the input guard.
ENABLE_OUTPUT_AUDIT=false
OUTPUT_AUDIT_MODEL=
# Soft scope (Phase 1.18, default off): stop hard-refusing on SCOPE — security/safety tiers still
# hard-block; off-topic is allowed through and refused by graceful-degradation. A/B before enabling.
ENABLE_SOFT_SCOPE=false

# -----------------------------------------------------------------------------
# Vector database
# Qdrant is the canonical backend. Leave QDRANT_URL empty to use local embedded
# Qdrant at QDRANT_LOCAL_PATH; set QDRANT_URL + QDRANT_API_KEY for Qdrant Cloud.
# Pinecone/Chroma are opt-in: change VECTOR_STORE_BACKEND and install their extras
# with `pip install -e ".[vector-backups]"` plus the relevant keys below.
# -----------------------------------------------------------------------------
VECTOR_STORE_BACKEND=qdrant
QDRANT_URL=
QDRANT_API_KEY=
# Phase 1.13/1.14 promoted collection: e5-large embeddings, hardened-parser calendar, --vinuni-only
# (10,967 chunks). Eval 0.946 / guards 1.000. (Old 3-small collection was `vinuni_documents`.)
QDRANT_COLLECTION=vinuni_full_e5
QDRANT_LOCAL_PATH=data/qdrant
QDRANT_TIMEOUT_SECONDS=120
QDRANT_BATCH_SIZE=16
CHROMA_COLLECTION=vinuni_documents
CHROMA_PERSIST_DIR=data/chroma
PINECONE_API_KEY=
PINECONE_INDEX_NAME=vinuni-documents
PINECONE_NAMESPACE=

# -----------------------------------------------------------------------------
# LangGraph short-term memory
# CHECKPOINTER_BACKEND=memory is fine for local dev.
# Use CHECKPOINTER_BACKEND=postgres with POSTGRES_URI for production.
# -----------------------------------------------------------------------------
CHECKPOINTER_BACKEND=memory
POSTGRES_URI=

# -----------------------------------------------------------------------------
# Data paths
# raw: normalized crawled documents
# processed: crawl manifest, structured records, chunks
# -----------------------------------------------------------------------------
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# -----------------------------------------------------------------------------
# Crawler
# Used by scripts/crawl_seed.py and POST /ingest/run.
# -----------------------------------------------------------------------------
CRAWL_USER_AGENT=VinChatbotBot/0.1 (+https://vinuni.edu.vn)
CRAWL_TIMEOUT_SECONDS=30
CRAWL_RATE_LIMIT_SECONDS=0.5

# -----------------------------------------------------------------------------
# Crawl safety bounds
# -----------------------------------------------------------------------------
CRAWL_MAX_PAGES_TOTAL=50000
CRAWL_MAX_VINUNI_PAGES_PER_DOMAIN=10000
CRAWL_MAX_EXTERNAL_PAGES_PER_DOMAIN=250
CRAWL_VINUNI_MAX_DEPTH=25
CRAWL_EXTERNAL_MAX_DEPTH=3

# -----------------------------------------------------------------------------
# Asset metadata
# ENABLE_IMAGE_ASSET_EXTRACTION=true stores image/file/table metadata.
# IMAGE_DOWNLOAD_ENABLED=false means HTML images are described from context only.
# Turn IMAGE_DOWNLOAD_ENABLED=true only when you want direct image fetching/OCR.
# -----------------------------------------------------------------------------
ENABLE_IMAGE_ASSET_EXTRACTION=true
IMAGE_DOWNLOAD_ENABLED=false
IMAGE_MAX_ASSET_MB=5
IMAGE_DESCRIPTION_MODE=context

# -----------------------------------------------------------------------------
# OCR
# Selected engine/model: PaddleOCR PP-OCRv5 English.
# Disabled by default because PaddleOCR is optional and heavy.
# PDF pages are OCR candidates when text length is below OCR_MIN_TEXT_CHARS_PER_PAGE.
# -----------------------------------------------------------------------------
ENABLE_OCR=false
OCR_ENGINE=paddleocr
OCR_LANG=en
OCR_MODEL=PP-OCRv5
OCR_MAX_IMAGE_MB=5
OCR_MAX_PDF_PAGES=20
OCR_MIN_TEXT_CHARS_PER_PAGE=40
OCR_STORE_TEXT=true
OCR_STORE_BOXES=false
