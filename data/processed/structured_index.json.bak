cy", "source_id": "ff995913d7d93a383fce19584fb9d044c340666a67bd356761ddd658aa7fe934", "canonical_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "document_title": "Guidelines for Student Financial Aid Support Request", "domain": "policy.vinuni.edu.vn", "domain_type": "policy", "source_trust": "official_high", "category": "student_affairs", "subcategory": "financial", "parser_name": "crawler", "parser_version": "v3", "source_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "final_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "crawl_depth": 0, "discovered_from": "seed", "http_status": 200, "content_type": "text/html; charset=UTF-8", "mime_type": "text/html", "file_size_bytes": 50535, "fetched_at": "2026-06-20T03:07:56.172578+00:00", "robots_allowed": true, "requires_login": false, "noindex": false, "access_level": "public", "crawl_run_id": "2f55a9b8-0bc8-4015-8aac-656a596ffa66", "reference_number": "GDL-FAO-001-V2.0", "document_status": "Guideline", "issuing_unit": "Financial Aid Office", "issued_date": "Apr 22, 2025", "applying_for": "All VinUniversity", "security_classification": "Public", "pdf_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "link_count": 13}}]