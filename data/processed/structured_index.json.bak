\n(Financial Support\nRequest Procedures) –\nStep 2 (Submit Financial\nSupport Request)", "content_hash": "44768e4c5147b19de5286914594748c9dc7f468de07292424cbaafcaf7b3a4ea"}, "metadata": {"source_kind": "policy_pdf", "source_id": "09f5b80e6a2b583755ca37f5ca63685d671b7d982bc00a34a620b773c3cfd90d", "canonical_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "document_title": "GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "domain": "policy.vinuni.edu.vn", "domain_type": "policy", "source_trust": "official_high", "category": "student_affairs", "subcategory": "financial", "parser_name": "pdf", "parser_version": "v3", "source_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "final_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "parent_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "crawl_depth": 1, "anchor_text": "Guidelines for Student Financial Aid Support Request", "link_context": "You can download this document here: Guidelines for Student Financial Aid Support Request", "discovered_from": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "http_status": 200, "content_type": "application/pdf", "mime_type": "application/pdf", "file_size_bytes": 323501, "etag": "\"4efad-68bc202b-407f8f;;;\"", "last_modified_header": "Sat, 06 Sep 2025 11:51:07 GMT", "fetched_at": "2026-06-20T03:13:46.606413+00:00", "robots_allowed": true, "requires_login": false, "noindex": false, "access_level": "public", "crawl_run_id": "2f55a9b8-0bc8-4015-8aac-656a596ffa66", "content_hash": "b1c387b651f8d6d9500b7f7a92bdcf9c4ef9abdf574b8649d7241963548f952f", "page_count": 5, "needs_ocr"