icy_pdf", "source_id": "09f5b80e6a2b583755ca37f5ca63685d671b7d982bc00a34a620b773c3cfd90d", "canonical_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "document_title": "GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "domain": "policy.vinuni.edu.vn", "domain_type": "policy", "source_trust": "official_high", "category": "student_affairs", "subcategory": "financial", "parser_name": "pdf", "parser_version": "v3", "source_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "final_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "parent_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "crawl_depth": 1, "anchor_text": "Guidelines for Student Financial Aid Support Request", "link_context": "You can download this document here: Guidelines for Student Financial Aid Support Request", "discovered_from": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "http_status": 200, "content_type": "application/pdf", "mime_type": "application/pdf", "file_size_bytes": 323501, "etag": "\"4efad-68bc202b-407f8f;;;\"", "last_modified_header": "Sat, 06 Sep 2025 11:51:07 GMT", "fetched_at": "2026-06-20T03:13:46.606413+00:00", "robots_allowed": true, "requires_login": false, "noindex": false, "access_level": "public", "crawl_run_id": "2f55a9b8-0bc8-4015-8aac-656a596ffa66", "content_hash": "b1c387b651f8d6d9500b7f7a92bdcf9c4ef9abdf574b8649d7241963548f952f", "page_count": 5, "needs_ocr": false, "page_number": 3, "table_id": "f4f81092faad2105489c092683ec6db65c84cbcf4bf3237540f5776c9b9453fe"}}, {"record_id": "98ed3e7cf36813842baab9b3fc47fe9c0f09cf850cf3e4a83f489814f1cf5a4b", "record_type": "table_record", "parent_doc_id": "09f5b80e6a2b583755ca37f5ca63685d671b7d982bc00a34a620b773c3cfd90d", "source_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "title": "PDF table page 3", "data": {"table_id": "08c187927ed912e657654809b072303e650c13617d8fd18b87fb8195255ef0f8", "caption": null, "headers": ["Application period", "Processing deadline", "Effective semester"], "rows": [["20 June - 10 July", "02 August", "Fall semester"], ["10 October – 10 November", "10 December", "Spring semester"]], "row_count": 2, "column_count": 3, "section_path": [], "page_number": 3, "rag_text": "Table: GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf page 3\nColumns: Application period | Processing deadline | Effective semester\nRow 1: Application period: 20 June - 10 July | Processing deadline: 02 August | Effective semester: Fall semester\nRow 2: Application period: 10 October – 10 November | Processing deadline: 10 December | Effective semester: Spring semester", "content_hash": "7a8babf82f101c8114ba669ac96d10ccf348aa80d6f7133121160919603dac9f"}, "metadata": {"source_kind": "policy_pdf", "source_id": "09f5b80e6a2b583755ca37f5ca63685d671b7d982bc00a34a620b773c3cfd90d", "canonical_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "document_title": "GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "domain": "policy.vinuni.edu.vn", "domain_type": "policy", "source_trust": "official_high", "category": "student_affairs", "subcategory": "financial", "parser_name": "pdf", "parser_version": "v3", "source_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "final_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "parent_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "crawl_depth": 1, "anchor_text": "Guidelines for Student Financial Aid Support Request", "link_context": "You can download this document here: Guidelines for Student Financial Aid Support Request", "discovered_from": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "http_status": 200, "content_type": "application/pdf", "mime_type": "application/pdf", "file_size_bytes": 323501, "etag": "\"4efad-68bc202b-407f8f;;;\"", "last_modified_header": "Sat, 06 Sep 2025 11:51:07 GMT", "fetched_at": "2026-06-20T03:13:46.606413+00:00", "robots_allowed": true, "requires_login": false, "noindex": false, "access_level": "public", "crawl_run_id": "2f55a9b8-0bc8-4015-8aac-656a596ffa66", "content_hash": "b1c387b651f8d6d9500b7f7a92bdcf9c4ef9abdf574b8649d7241963548f952f", "page_count": 5, "needs_ocr": false, "page_number": 3, "table_id": "08c187927ed912e657654809b072303e650c13617d8fd18b87fb8195255ef0f8"}}, {"record_id": "00a2fc2aa249a43c2bcdb22d4ccb28669bf9257f0dbba38c090c88d6fe9f4b48", "record_type": "table_record", "parent_doc_id": "09f5b80e6a2b583755ca37f5ca63685d671b7d982bc00a34a620b773c3cfd90d", "source_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "title": "PDF table page 4", "data": {"table_id": "b96ce204747e14c743618ceec90eda8922f261a883d091d14ec0c83bde466e01", "caption": null, "headers": ["Steps", "Action", "Detailed Explanation"], "rows": [["1", "Gather\nRequired\nDocumentation", "Before submitting the request, students should collect all required\ndocuments, including:\n✓ Completed Financial Support Application Form (Link: Home\n(vinuni.edu.vn), section Request for FA)\n✓ Proof of financial need\n✓ Any additional supporting documents (e.g., letters explaining special\ncircumstances or medical bills)."], ["2", "Submit\nFinancial\nSupport\nRequest", "Submit the request online through the student portal. Ensure all the\nrequired documentations are attached.\nDeadlines:\n- All students: July 10th (for the Fall semester) and November 10th\n(for the Spring semester) each year.\n- Global Exchange Student Ambassador Grant: Based on the\nexchange nomination release timelines. Students can apply for\nthe GESA grant after they are nominated for an exchange\nprogram by VinUni."], ["3", "Initial Review\nby Financial\nAid Office\n(FAO)", "FAO will review the application for completeness and eligibility.\nIf their application is incomplete, the student will be notified within 03\nworking days."], ["4", "Review by\nFinancial Aid\nReview\nCommittee", "The committee, consisting of university staff and faculty, will evaluate the\nrequests based on:\n- Financial need\n- Academic standing\n- Availability of resources\n- Special circumstances\n- The students meeting the eligibility of each type of grants\nReview duration: 05 working days after receiving the review request from\nthe Financial Aid Office."], ["5", "Notification of\nDecision", "Students will be notified via email or the student portal within two working\ndays after the Financial Aid Review Committee makes the final decision.\nThe notification will include:\n- Decision (approved, denied, or request for further documentation)\n- Amount awarded (if applicable)\n- Instructions for next steps"], ["6", "Disbursement of\nFunds", "Approach for the disbursement of funds as below:\n• For tuition fees: The allocated funds will be directly applied to offset\nthe tuition fees and reflected in the student’s billing statement.\n• For non-tuition fees: Approved funds will be disbursed to the\nstudent’s VND bank account for relevant expenses. If the approved\nfunds are to be disbursed to a parent or relative, the student must\nprovide official authorization designating the recipient."]], "row_count": 6, "column_count": 3, "section_path": [], "page_number": 4, "rag_text": "Table: GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf page 4\nColumns: Steps | Action | Detailed Explanation\nRow 1: Steps: 1 | Action: Gather\nRequired\nDocumentation | Detailed Explanation: Before submitting the request, students should collect all required\ndocuments, including:\n✓ Completed Financial Support Application Form (Link: Home\n(vinuni.edu.vn), section Request for FA)\n✓ Proof of financial need\n✓ Any additional supporting documents (e.g., letters explaining special\ncircumstances or medical bills).\nRow 2: Steps: 2 | Action: Submit\nFinancial\nSupport\nRequest | Detailed Explanation: Submit the request online through the student portal. Ensure all the\nrequired documentations are attached.\nDeadlines:\n- All students: July 10th (for the Fall semester) and November 10th\n(for the Spring semester) each year.\n- Global Exchange Student Ambassador Grant: Based on the\nexchange nomination release timelines. Students can apply for\nthe GESA grant after they are nominated for an exchange\nprogram by VinUni.\nRow 3: Steps: 3 | Action: Initial Review\nby Financial\nAid Office\n(FAO) | Detailed Explanation: FAO will review the application for completeness and eligibility.\nIf their application is incomplete, the student will be notified within 03\nworking days.\nRow 4: Steps: 4 | Action: Review by\nFinancial Aid\nReview\nCommittee | Detailed Explanation: The committee, consisting of university staff and faculty, will evaluate the\nrequests based on:\n- Financial need\n- Academic standing\n- Availability of resources\n- Special circumstances\n- The students meeting the eligibility of each type of grants\nReview duration: 05 working days after receiving the review request from\nthe Financial Aid Office.\nRow 5: Steps: 5 | Action: Notification of\nDecision | Detailed Explanation: Students will be notified via email or the student portal within two working\ndays after the Financial Aid Review Committee makes the final decision.\nThe notification will include:\n- Decision (approved, denied, or request for further documentation)\n- Amount awarded (if applicable)\n- Instructions for next steps\nRow 6: Steps: 6 | Action: Disbursement of\nFunds | Detailed Explanation: Approach for the disbursement of funds as below:\n• For tuition fees: The allocated funds will be directly applied to offset\nthe tuition fees and reflected in the student’s billing statement.\n• For non-tuition fees: Approved funds will be disbursed to the\nstudent’s VND bank account for relevant expenses. If the approved\nfunds are to be disbursed to a parent or relative, the student must\nprovide official authorization designating the recipient.", "content_hash": "fa89a550e633409943fea01574e3b9cbae0dc05b3e42603d4d57b001f6a384c8"}, "metadata": {"source_kind": "policy_pdf", "source_id": "09f5b80e6a2b583755ca37f5ca63685d671b7d982bc00a34a620b773c3cfd90d", "canonical_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "document_title": "GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "domain": "policy.vinuni.edu.vn", "domain_type": "policy", "source_trust": "official_high", "category": "student_affairs", "subcategory": "financial", "parser_name": "pdf", "parser_version": "v3", "source_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "final_url": "https://policy.vinuni.edu.vn/wp-content/uploads/2024/09/GDL-FAO-001-V2.0_Guideline-for-Student-Financial-Support-Request_22.04.2025.pdf", "parent_url": "https://policy.vinuni.edu.vn/all-policies/guidelines-for-student-financial-support-request/", "crawl_depth": 1, "anchor_text": "Guidelines for Student Financial Aid Support Request", "link_context": "You can download this document here: Guidelines for Student F